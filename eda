df["genre_count"] = df["genres_list"].apply(len) #adds a new feature genre_count for how many genres per movie for sake of EDA
df["genre_count"].value_counts().sort_index().plot(kind="bar") #distribution of row-level counts
plt.title("Number of Genres per Movie")
plt.xlabel("Number of Genres")
plt.ylabel("Number of Movies")
plt.show()

df["vote_average"].dropna().plot(kind="hist", bins=20) #histogram showing distribution of float ratings 0-10
plt.title("Distribution of Movie Ratings")
plt.xlabel("Rating")
plt.ylabel("Frequency")
plt.xticks(range(0, 11))
plt.show()

df["release_date"] = pd.to_datetime(df["release_date"], errors="coerce") #changes format to datetime
df["year"] = df["release_date"].dt.year #makes a new feature to represent year
df["year"].dropna().astype(int).plot(kind="hist", bins=30) #takes out nulls, turns to int, makes histogram
plt.title("Distribution of Movie Release Year")
plt.xlabel("Year")
plt.ylabel("Count")
plt.xticks(range(1900, 2021, 10))
plt.show()

df["revenue"] = pd.to_numeric(df["revenue"], errors="coerce") #converts every data point to numeric (precaution)
df["revenue"] = df["revenue"].fillna(df["revenue"].median()) #replaces null values with the median number
df["revenue_scaled"] = df["revenue"] / 10000 #scales all numbers down by dividing by 10,000
plt.figure(figsize=(8,5))
plt.hist(df["revenue_scaled"], bins=30)
plt.title("Distribution of Movie Revenue")
plt.xlabel("Revenue (×10,000)")
plt.ylabel("Number of Movies")
plt.show()

df["vote_count"] = pd.to_numeric(df["vote_count"], errors="coerce") #converts every data point to numeric (precaution)
df["vote_count"].dropna().plot(kind="hist", bins=30)
plt.title("Distribution of Vote Count")
plt.xlabel("Number of Votes")
plt.ylabel("Frequency")
plt.show()

df["budget"] = pd.to_numeric(df["budget"], errors="coerce")  #converts every data point to numeric (precaution)
df["budget"] = df["budget"].fillna(df["budget"].median()) #replaces null values with the median number
df["budget_scaled"] = df["budget"] / 10000 #scales all numbers down by dividing by 10,000
plt.figure(figsize=(8,5))
plt.hist(df["budget_scaled"], bins=30)
plt.title("Distribution of Movie Budget")
plt.xlabel("Budget (×10,000)")
plt.ylabel("Frequency")
plt.ticklabel_format(style='plain', axis='x')
plt.show()
